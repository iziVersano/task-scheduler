{
  "name": "task-scheduler",
  "version": "1.0.0",
  "description": "Local web app to manage and track scheduled tasks",
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,magenta \"npm run server\" \"npm run client:dev\"",
    "server": "node --no-warnings server/index.js",
    "client:dev": "npm run dev --prefix client",
    "install:all": "npm install && npm install --prefix client"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@aws-sdk/client-cost-explorer": "^3.1015.0",
    "@aws-sdk/client-ec2": "^3.1015.0",
    "@aws-sdk/client-guardduty": "^3.1015.0",
    "@aws-sdk/client-iam": "^3.1015.0",
    "@aws-sdk/client-lambda": "^3.1015.0",
    "@aws-sdk/client-s3": "^3.1015.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.3",
    "jose": "^6.2.2",
    "node-cron": "^3.0.3",
    "puppeteer-core": "^24.37.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
